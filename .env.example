# =============================================================================
# CrewAI + Gemini 3.5 Flash — environment variables
# Copy this file to `.env` and fill in your real values:
#     cp .env.example .env       (macOS / Linux)
#     copy .env.example .env     (Windows)
# =============================================================================

# --- Google Gemini API key (REQUIRED) ----------------------------------------
# Get one for free at https://aistudio.google.com/app/apikey
# Either GEMINI_API_KEY or GOOGLE_API_KEY works — CrewAI accepts both.
GEMINI_API_KEY=your-gemini-api-key-here
# GOOGLE_API_KEY=your-gemini-api-key-here

# --- Optional: Vertex AI Express mode ----------------------------------------
# Uncomment BOTH lines below to use Vertex AI Express mode with an API key
# instead of a service-account JSON file.
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_API_KEY=your-google-cloud-api-key-here
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Olostep Web Data API (optional but recommended) ------------------------
# Used by the Researcher's `olostep_web_search` and `olostep_scrape_url` tools
# so the agent can pull live information from the web. Free key at
# https://www.olostep.com/dashboard/
# OLOSTEP_API_KEY=your-olostep-api-key-here

# --- Optional: Serper.dev (only needed if you add web search tools) ---------
# Get a free key at https://serper.dev/
# SERPER_API_KEY=your-serper-api-key
